{
  "version": 1,
  "printMode": "tcp",
  "tcp": {
    "host": "192.168.1.50",
    "port": 9100,
    "timeoutMs": 5000
  },
  "encoding": "latin1",
  "sanitizeValues": true,
  "trigger": {
    "dpe": "System1:RfidLabel.cmd.print",
    "mode": "onTrue",
    "resetAfterPrint": true
  },
  "status": {
    "dpe": "System1:RfidLabel.status"
  },
  "template": "^XA\n^CI28\n^PW600\n^LL400\n^RS8\n^RFW,H^FD{{serial}}^FS\n^RMD,0,3,V\n^CF0,30\n^FO40,40^FDProduit : {{product}}^FS\n^FO40,90^FDS/N RFID : {{serial}}^FS\n^FO40,150^BY3\n^BCN,120,Y,N,N^FD{{serial}}^FS\n^PQ1\n^XZ",
  "fields": [
    { "name": "product", "dpe": "System1:RfidLabel.product", "default": "N/A", "transform": "trim" },
    { "name": "serial", "dpe": "System1:RfidLabel.serial", "default": "000000000000", "transform": "upper" }
  ]
}
